# These vars are required by the two Flask APIs (announcement-api,
# collection-api). The running containers read them from ~/DockerApps/.env via
# docker-compose's ${VAR} substitution. This file is a documentation stub —
# copy values from your real .env when bringing up a fresh deployment.

# Plex
PLEX_TOKEN=your-plex-x-plex-token-here

# Arr stack
SONARR_API_KEY=your-sonarr-api-key
RADARR_API_KEY=your-radarr-api-key
TAUTULLI_API_KEY=your-tautulli-api-key
SEERR_API_KEY=your-seerr-api-key

# Admin-key gates (announcement-api, collection-api)
ADMIN_KEY=pick-a-long-random-string
KELLY_KEY=pick-another-long-random-string

# Optional: MDB List for the trending-movies widget on the status hub
MDBLIST_API_KEY=

# Outbound email (Gmail SMTP). SMTP_USER / ADMIN_EMAIL are passed inline in
# docker-compose.yaml; only SMTP_PASS (the Gmail app password) lives here.
SMTP_PASS=your-gmail-app-password
